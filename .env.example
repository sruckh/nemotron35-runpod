# Copy to .env (or set as RunPod pod env vars). Defaults shown.

# --- model ---
MODEL_NAME=nvidia/nemotron-3.5-asr-streaming-0.6b
DEVICE=cuda

# --- streaming latency / language (PROCESS-GLOBAL: restart pod to change) ---
# Right context N in {0,1,3,6,13} -> chunk 80/160/320/560/1120 ms. Default 320 ms.
ATT_CONTEXT_N=3
TARGET_LANG=auto           # locale e.g. en-US, es-ES, de-DE; or "auto" for lang detection
STRIP_LANG_TAGS=true       # remove the trailing <xx-XX> language tag
ONLINE_NORMALIZATION=true

# --- compute (cache-aware models require float32 weights; amp autocast = speedup) ---
AMP=false                  # set true on H100 for bf16 autocast speedup
AMP_DTYPE=bfloat16         # bfloat16 | float16 (only when AMP=true)

# --- Gradio web UI ---
GRADIO_PORT=7860
SHARE_LINK=true            # create a public https://<id>.gradio.live link (bypasses RunPod proxy)
GRADIO_AUTH=               # optional "user:pass" gate on the public link
MAX_CONCURRENT_STREAMS=8
STREAM_EVERY_S=0.5         # seconds between mic chunks sent to the model
STREAM_TIME_LIMIT_S=600    # max seconds per recording

# --- runtime bootstrap (entrypoint.sh) ---
PREFETCH_MODEL=1
MODEL_CACHE=/workspace/hf_cache     # RunPod network volume strongly recommended
PIP_CACHE=/workspace/pip_cache
NEMO_REF=main                      # pin to a tag once NeMo 26.06 ships
# HF_TOKEN=                         # only if the model is gated
